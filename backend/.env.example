# Copia este archivo a ".env" y ajusta los valores para tu entorno.

# Cadena de conexión a PostgreSQL: usuario:contraseña@host:puerto/basededatos
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurante?schema=public"

# Secreto usado para firmar los tokens JWT. Cambialo por un valor largo y aleatorio en producción.
JWT_SECRET="cambia-este-valor-por-un-secreto-largo-y-aleatorio"

# Tiempo de expiración de los tokens de sesión
JWT_EXPIRES_IN="12h"

# Puerto donde corre el backend
PORT=4000

# Origen permitido para CORS (la URL donde corre el frontend)
CORS_ORIGIN="http://localhost:5173"
